<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ========== BASE APP THEME ========== -->
    <style name="Base.Theme.Shope" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_surface</item>
        <item name="colorOnPrimaryContainer">@color/primary_darker</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_surface</item>
        <item name="colorOnSecondaryContainer">@color/secondary_dark</item>

        <!-- Background & Surface — let Material3 DayNight handle these automatically -->

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Dialog styling — use MaterialAlertDialog overlay -->
        <item name="materialAlertDialogTheme">@style/Shope.AlertDialog</item>

        <!-- Typography -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#1A5C6BC0</item>
    </style>

    <!-- Dialog overlay: always white background, dark text, colored buttons -->
    <style name="Shope.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1D2E</item>
        <item name="android:textColorPrimary">#1A1D2E</item>
        <item name="android:textColorSecondary">#5C6380</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Material3.Button.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Material3.Button.TextButton</item>
    </style>

    <style name="Theme.Shope" parent="Base.Theme.Shope" />

    <!-- ========== TEXT APPEARANCE STYLES ========== -->
    <style name="TextAppearance.Shope.PageTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Shope.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Shope.CardLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Shope.CardValue" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- ========== BUTTON STYLES ========== -->
    <style name="Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_height">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
    </style>

    <style name="Button.Danger" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_height">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/error_light</item>
        <item name="android:textColor">@color/error</item>
    </style>

    <!-- ========== CARD STYLES ========== -->
    <style name="CardStyle.Default" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="CardStyle.Stat" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- ========== TEXT INPUT STYLES ========== -->
    <style name="TextInput.Rounded" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/primary_light</item>
    </style>

    <!-- ========== BOTTOM NAV STYLE ========== -->
    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@drawable/nav_icon_color</item>
        <item name="itemTextColor">@drawable/nav_icon_color</item>
        <item name="indicatorColor">@android:color/transparent</item>
        <item name="itemPaddingTop">12dp</item>
        <item name="itemPaddingBottom">12dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- ========== FAB STYLE ========== -->
    <style name="FABStyle" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
        <item name="elevation">8dp</item>
    </style>

    <!-- ========== TOOLBAR STYLE ========== -->
    <style name="ToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- Shape Appearance -->
    <style name="ShapeAppearance.Shope.RoundedAll" parent="ShapeAppearance.Material3.Corner.Full"/>
    <style name="ShapeAppearance.Shope.RoundedMedium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>
    <style name="ShapeAppearance.Shope.RoundedTop" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>